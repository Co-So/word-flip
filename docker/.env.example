# WordFlip local infrastructure — copy to .env and adjust before `docker compose up -d`
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)

# ── MySQL 8 ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=wordflip
MYSQL_PORT=3306

# ── Redis 7 ──────────────────────────────────────────────────────────────────
REDIS_PORT=6379
# Leave empty for no auth in local dev; set a value to enable --requirepass
REDIS_PASSWORD=

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=wordflip
